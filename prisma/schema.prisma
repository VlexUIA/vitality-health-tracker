generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CalorieEntry {
  id        Int      @id @default(autoincrement())
  date      String
  meal      String
  calories  Int
  protein   Float?
  carbs     Float?
  fat       Float?
  createdAt DateTime @default(now())
}

model WaterEntry {
  id        Int      @id @default(autoincrement())
  date      String
  amount    Int
  createdAt DateTime @default(now())
}

model VitaminEntry {
  id        Int      @id @default(autoincrement())
  date      String
  name      String
  taken     Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SleepEntry {
  id        Int      @id @default(autoincrement())
  date      String
  bedtime   String
  wakeTime  String
  duration  Float
  quality   Int
  fromWatch Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EnergyEntry {
  id        Int      @id @default(autoincrement())
  date      String
  level     Int
  note      String?
  createdAt DateTime @default(now())
}

model StimulantEntry {
  id            Int      @id @default(autoincrement())
  date          String
  time          String
  name          String
  caffeineMg    Int
  durationHours Float
  createdAt     DateTime @default(now())
}

model CustomStimulant {
  id            Int      @id @default(autoincrement())
  name          String
  caffeineMg    Int
  durationHours Float
  createdAt     DateTime @default(now())
}

model Settings {
  id           Int    @id @default(autoincrement())
  calorieGoal  Int    @default(2000)
  waterGoal    Int    @default(2500)
  proteinGoal  Int    @default(150)
  vitamins     String @default("[]")
  apiKey       String @default("")
}
